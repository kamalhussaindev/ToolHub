---
import ToolLayout from '../../layouts/ToolLayout.astro';
import DisclaimerNote from '../../components/DisclaimerNote.astro';
import { getCluster } from '../../data/clusters';
import { getLiveTools, getTool } from '../../data/tools';
import { ISLAMIC_LAST_REVIEWED } from '../../data/islamic';

import TileCalculator from '../../components/tools/TileCalculator.astro';
import PaintCalculator from '../../components/tools/PaintCalculator.astro';
import FlooringCalculator from '../../components/tools/FlooringCalculator.astro';
import WallpaperCalculator from '../../components/tools/WallpaperCalculator.astro';
import FabricCalculator from '../../components/tools/FabricCalculator.astro';
import ZakatCalculator from '../../components/tools/ZakatCalculator.astro';
import ZakatOnGoldCalculator from '../../components/tools/ZakatOnGoldCalculator.astro';
import HijriDateConverter from '../../components/tools/HijriDateConverter.astro';
import UuidGenerator from '../../components/tools/UuidGenerator.astro';
import SlugGenerator from '../../components/tools/SlugGenerator.astro';
import SitemapValidator from '../../components/tools/SitemapValidator.astro';
import GpaToPercentageCalculator from '../../components/tools/GpaToPercentageCalculator.astro';
import SgpaToPercentageCalculator from '../../components/tools/SgpaToPercentageCalculator.astro';
import MarksPercentageCalculator from '../../components/tools/MarksPercentageCalculator.astro';
import AttendanceCalculator from '../../components/tools/AttendanceCalculator.astro';
import DogAgeCalculator from '../../components/tools/DogAgeCalculator.astro';
import FlamesCalculator from '../../components/tools/FlamesCalculator.astro';
import AbvCalculator from '../../components/tools/AbvCalculator.astro';
import CompressImageToKb from '../../components/tools/CompressImageToKb.astro';
import ReducePhotoSizeInKb from '../../components/tools/ReducePhotoSizeInKb.astro';
import CompressImageTo20Kb from '../../components/tools/CompressImageTo20Kb.astro';
import CompressImageTo50Kb from '../../components/tools/CompressImageTo50Kb.astro';
import CompressImageTo100Kb from '../../components/tools/CompressImageTo100Kb.astro';
import CompressImageTo200Kb from '../../components/tools/CompressImageTo200Kb.astro';
import CompressImageTo500Kb from '../../components/tools/CompressImageTo500Kb.astro';
import CompressImageTo1Mb from '../../components/tools/CompressImageTo1Mb.astro';

// Astro (vanilla) components, rendered with no client directive.
const astroComponentMap = {
  TileCalculator,
  PaintCalculator,
  FlooringCalculator,
  WallpaperCalculator,
  FabricCalculator,
  ZakatCalculator,
  ZakatOnGoldCalculator,
  HijriDateConverter,
  UuidGenerator,
  SlugGenerator,
  SitemapValidator,
  GpaToPercentageCalculator,
  SgpaToPercentageCalculator,
  MarksPercentageCalculator,
  AttendanceCalculator,
  DogAgeCalculator,
  FlamesCalculator,
  AbvCalculator,
  CompressImageToKb,
  ReducePhotoSizeInKb,
  CompressImageTo20Kb,
  CompressImageTo50Kb,
  CompressImageTo100Kb,
  CompressImageTo200Kb,
  CompressImageTo500Kb,
  CompressImageTo1Mb,
} as const;

// Preact islands — these are JS-heavy converters that need client:visible to
// hydrate, which Astro only allows on framework components, not .astro ones.
import XmlToJson from '../../components/tools/XmlToJson';
import YamlToJson from '../../components/tools/YamlToJson';
import JsonToXml from '../../components/tools/JsonToXml';

const PREACT_COMPONENTS = ['XmlToJson', 'YamlToJson', 'JsonToXml'];

export function getStaticPaths() {
  return getLiveTools().map((tool) => ({
    params: { cluster: tool.cluster, tool: tool.slug },
  }));
}

const { cluster: clusterSlug, tool: toolSlug } = Astro.params;
const tool = getTool(toolSlug)!;
const cluster = getCluster(clusterSlug)!;
const ToolComponent = astroComponentMap[tool.component as keyof typeof astroComponentMap];
const isPreact = PREACT_COMPONENTS.includes(tool.component);
---

<ToolLayout tool={tool} cluster={cluster}>
  {isPreact ? (
    <Fragment slot="tool">
      {tool.component === 'XmlToJson' && <XmlToJson client:visible />}
      {tool.component === 'YamlToJson' && <YamlToJson client:visible />}
      {tool.component === 'JsonToXml' && <JsonToXml client:visible />}
    </Fragment>
  ) : (
    <ToolComponent slot="tool" />
  )}
  {tool.showDisclaimer && <DisclaimerNote slot="footer-note" lastReviewed={ISLAMIC_LAST_REVIEWED} />}
</ToolLayout>

<script define:vars={{ toolSlug: tool.slug }} is:inline>
  // Track this tool visit for the homepage's "recently opened" section.
  try {
    const KEY = 'toolhub-recents';
    const existing = JSON.parse(localStorage.getItem(KEY) || '[]');
    const next = [toolSlug, ...existing.filter((id) => id !== toolSlug)].slice(0, 6);
    localStorage.setItem(KEY, JSON.stringify(next));
  } catch {
    // localStorage unavailable — recents personalization simply won't apply.
  }
</script>
