---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { guides } from '../../data/guides';
---

<BaseLayout
  title="Guides — Tool Hub"
  description="In-depth guides to help you get the most out of our calculators and converters."
  canonicalPath="/guides/"
>
  <div class="container guides-hub">
    <Breadcrumbs crumbs={[{ name: 'Home', path: '/' }, { name: 'Guides', path: '/guides/' }]} />
    <h1>Guides</h1>
    <p>In-depth explainers that link straight into the tool you need.</p>

    {guides.length > 0 ? (
      <ul class="guides-hub__list">
        {guides.map((guide) => (
          <li>
            <a href={`/guides/${guide.slug}/`}>{guide.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p>No guides published yet — check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .guides-hub {
    max-width: var(--tool-width);
    padding: var(--space-8) 0 var(--space-10);
  }
  .guides-hub__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
</style>
