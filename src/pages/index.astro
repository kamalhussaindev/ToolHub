---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import ToolCard from '../components/ToolCard.astro';
import { getSortedClusters } from '../data/clusters';
import { getToolsByCluster } from '../data/tools';

const clusters = getSortedClusters();

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Tool Hub',
    url: Astro.site,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${Astro.site}?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Tool Hub',
    url: Astro.site,
  },
];
---

<BaseLayout
  title="Tool Hub — Free Online Tools & Calculators"
  description="Free, fast, no-signup calculators and converters for home improvement, Islamic finance, developers, students, and everyday life."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero__inner">
      <h1>Free Online Tools &amp; Calculators</h1>
      <p>Fast, accurate, no signup required — every calculation runs right in your browser.</p>
      <SearchBar />
    </div>
  </section>

  {clusters.map((cluster) => {
    const clusterTools = getToolsByCluster(cluster.slug);
    return (
      <section class="category-section" style={`--card-accent: ${cluster.accent}`}>
        <div class="container">
          <div class="category-section__header">
            <h2>{cluster.name}</h2>
            <a class="category-section__link" href={`/${cluster.slug}/`}>View all →</a>
          </div>
          <p class="category-section__tagline">{cluster.tagline}</p>
          <div class="grid grid--tools">
            {clusterTools.map((tool) => <ToolCard tool={tool} />)}
          </div>
        </div>
      </section>
    );
  })}

  <section class="section trust-strip">
    <div class="container trust-strip__grid">
      <div>
        <h3>⚡ Fast</h3>
        <p>Instant, live results — no page reloads, no waiting.</p>
      </div>
      <div>
        <h3>🆓 Free</h3>
        <p>Every tool is free to use, with no account required.</p>
      </div>
      <div>
        <h3>📱 Works anywhere</h3>
        <p>Fully responsive and keyboard-friendly on any device.</p>
      </div>
      <div>
        <h3>🔒 Private</h3>
        <p>Calculations run in your browser — your data is never uploaded.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }
  .hero__inner {
    max-width: 640px;
    text-align: center;
    padding: var(--space-10) var(--space-5);
  }
  .hero h1 {
    font-size: var(--text-3xl);
  }
  .hero p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
  .category-section {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .category-section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .category-section__header h2 {
    border-left: 4px solid var(--card-accent);
    padding-left: var(--space-3);
  }
  .category-section__link {
    font-size: var(--text-sm);
    font-weight: 600;
    white-space: nowrap;
  }
  .category-section__tagline {
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }
  .trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-6);
    text-align: center;
  }
  .trust-strip__grid h3 {
    font-size: var(--text-base);
  }
  .trust-strip__grid p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0;
  }
</style>
