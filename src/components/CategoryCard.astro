---
import type { Cluster } from '../data/clusters';
import { getToolsByCluster } from '../data/tools';
import { icon } from '../data/icons';

export interface Props {
  cluster: Cluster;
}

const { cluster } = Astro.props;
const clusterTools = getToolsByCluster(cluster.slug);
const examples = clusterTools.slice(0, 3);
---

<a class="category-card" href={`/${cluster.slug}/`} style={`--cat:${cluster.color};--cat-soft:${cluster.soft}`}>
  <span class="arr">↗</span>
  <span class="cat-main">
    <span class="cat-ico" set:html={icon(cluster.icon)} />
    <span class="cat-copy">
      <strong>{cluster.name}</strong>
      <small>{clusterTools.length} tool{clusterTools.length === 1 ? '' : 's'}</small>
    </span>
  </span>
  <span class="cat-preview">
    {examples.map((t) => <span>{t.title}</span>)}
  </span>
</a>
