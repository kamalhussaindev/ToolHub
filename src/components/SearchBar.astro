---
import { getLiveTools } from '../data/tools';
import { getCluster } from '../data/clusters';

export interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const index = getLiveTools().map((tool) => ({
  slug: tool.slug,
  title: tool.title,
  cluster: tool.cluster,
  clusterName: getCluster(tool.cluster)?.name ?? '',
  keywords: tool.keywords,
}));
---

<div class:list={['search-bar', { 'search-bar--compact': compact }]} data-search-root>
  <label class="visually-hidden" for={`search-input-${compact ? 'compact' : 'hero'}`}>Search tools</label>
  <input
    id={`search-input-${compact ? 'compact' : 'hero'}`}
    type="search"
    placeholder="Search 25+ free tools…"
    autocomplete="off"
    data-search-input
  />
  <ul class="search-bar__results" data-search-results hidden></ul>
  <script type="application/json" data-search-index is:inline set:html={JSON.stringify(index)} />
</div>

<script>
  interface SearchItem {
    slug: string;
    title: string;
    cluster: string;
    clusterName: string;
    keywords: string[];
  }

  document.querySelectorAll<HTMLElement>('[data-search-root]').forEach((root) => {
    const input = root.querySelector<HTMLInputElement>('[data-search-input]');
    const resultsEl = root.querySelector<HTMLUListElement>('[data-search-results]');
    const indexEl = root.querySelector<HTMLScriptElement>('[data-search-index]');
    if (!input || !resultsEl || !indexEl) return;

    const items: SearchItem[] = JSON.parse(indexEl.textContent || '[]');

    function search(query: string): SearchItem[] {
      const q = query.trim().toLowerCase();
      if (!q) return [];
      return items
        .map((item) => {
          const haystack = [item.title, ...item.keywords].join(' ').toLowerCase();
          const score = haystack.includes(q) ? (item.title.toLowerCase().includes(q) ? 2 : 1) : 0;
          return { item, score };
        })
        .filter((r) => r.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 8)
        .map((r) => r.item);
    }

    function render(results: SearchItem[]) {
      if (!resultsEl) return;
      resultsEl.innerHTML = '';
      if (results.length === 0) {
        resultsEl.hidden = true;
        return;
      }
      results.forEach((item) => {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `/${item.cluster}/${item.slug}/`;
        a.innerHTML = `<span>${item.title}</span><small>${item.clusterName}</small>`;
        li.appendChild(a);
        resultsEl.appendChild(li);
      });
      resultsEl.hidden = false;
    }

    input.addEventListener('input', () => render(search(input.value)));
    input.addEventListener('focus', () => render(search(input.value)));
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        resultsEl.hidden = true;
      }
    });
  });
</script>

<style>
  .search-bar {
    position: relative;
  }
  .search-bar input {
    width: 100%;
  }
  .search-bar--compact input {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
  }
  .search-bar__results {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    z-index: 60;
    max-height: 320px;
    overflow-y: auto;
  }
  .search-bar__results li a {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--color-text);
  }
  .search-bar__results li a:hover,
  .search-bar__results li a:focus-visible {
    background: var(--color-primary-soft);
    text-decoration: none;
  }
  .search-bar__results li small {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }
</style>
