---
import type { Tool } from '../data/tools';
import { getCluster } from '../data/clusters';
import { icon } from '../data/icons';

export interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const cluster = getCluster(tool.cluster);
const isLive = tool.status === 'live';
const href = `/${tool.cluster}/${tool.slug}/`;
const style = `--tool:${cluster?.color ?? '#5567f2'};--tool-soft:${cluster?.soft ?? '#eef0ff'}`;
---

<article class={`tool-card ${isLive ? '' : 'tool-card--disabled'}`} style={style} aria-disabled={isLive ? undefined : 'true'}>
  <div class="top">
    <div class="tool-ico" set:html={icon(tool.icon)} />
    {isLive && (
      <button class="fav" data-fav={tool.slug} aria-label={`Save ${tool.title} to favorites`} type="button" set:html={icon('heart')} />
    )}
  </div>
  {tool.popular && isLive && <span class="popular-label">Popular</span>}
  <h3>
    {isLive ? <a class="tool-card__link" href={href}>{tool.title}</a> : tool.title}
  </h3>
  <p>{tool.intro}</p>
  <div class="tool-meta">
    {isLive ? <span class="badge">{cluster?.name}</span> : <span class="badge">Coming soon</span>}
    {isLive && <span class="open-circle">→</span>}
  </div>
</article>

<style>
  .tool-card {
    position: relative;
  }
  .tool-card__link {
    position: static;
  }
  .tool-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .tool-card .fav {
    position: relative;
    z-index: 2;
  }
  .tool-card--disabled {
    opacity: 0.65;
  }
</style>
