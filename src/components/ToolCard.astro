---
import type { Tool } from '../data/tools';
import { getCluster } from '../data/clusters';

export interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const cluster = getCluster(tool.cluster);
const isLive = tool.status === 'live';
const href = `/${tool.cluster}/${tool.slug}/`;
---

{isLive ? (
  <a class="tool-card" href={href} style={`--card-accent: ${cluster?.accent ?? 'var(--color-primary)'}`}>
    <h3>{tool.title}</h3>
    <p>{tool.intro}</p>
  </a>
) : (
  <div class="tool-card tool-card--disabled" style={`--card-accent: ${cluster?.accent ?? 'var(--color-primary)'}`} aria-disabled="true">
    <h3>{tool.title} <span class="badge">Coming soon</span></h3>
    <p>{tool.intro}</p>
  </div>
)}

<style>
  .tool-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--card-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  a.tool-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .tool-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .tool-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
  .tool-card--disabled {
    opacity: 0.65;
    cursor: default;
  }
</style>
