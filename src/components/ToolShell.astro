---
import type { Tool } from '../data/tools';
import type { Cluster } from '../data/clusters';
import { getRelated } from '../data/tools';
import { getCluster } from '../data/clusters';
import { icon } from '../data/icons';
import Breadcrumbs from './Breadcrumbs.astro';
import AdSlot from './AdSlot.astro';
import FaqAccordion from './FaqAccordion.astro';

export interface Props {
  tool: Tool;
  cluster: Cluster;
}

const { tool, cluster } = Astro.props;
const related = getRelated(tool.slug);

const tocItems = [
  { href: '#calculator-heading', label: 'Calculator' },
  ...(tool.articleHtml ? [{ href: '#article-heading', label: 'Full guide' }] : []),
  ...(tool.howToUse.length > 0 ? [{ href: '#how-to-use-heading', label: 'How to use it' }] : []),
  ...(tool.howItWorks ? [{ href: '#how-it-works-heading', label: 'Formula and explanation' }] : []),
  ...(tool.examples && tool.examples.length > 0 ? [{ href: '#examples-heading', label: 'Examples' }] : []),
  ...(tool.faqs.length > 0 ? [{ href: '#faq-heading', label: 'FAQ' }] : []),
  ...(related.length > 0 ? [{ href: '#related-heading', label: 'Related tools' }] : []),
];
---

<section class="tool-page">
  <div class="shell">
    <Breadcrumbs
      crumbs={[
        { name: 'Home', path: '/' },
        { name: cluster.name, path: `/${cluster.slug}/` },
        { name: tool.title, path: `/${cluster.slug}/${tool.slug}/` },
      ]}
    />

    <div class="tool-heading">
      <div>
        <h1 id="calculator-heading">{tool.h1}</h1>
        <p>{tool.intro}</p>
      </div>
      <div class="tool-actions">
        <button class="small-btn" data-fav={tool.slug} type="button">
          <span set:html={icon('bookmark')} /> Save
        </button>
        <button class="small-btn" id="shareTool" type="button">
          <span set:html={icon('share')} /> Share
        </button>
      </div>
    </div>

    <slot name="tool" />

    <AdSlot slot={`tool-${cluster.slug}-${tool.slug}`} />

    <div class="content-layout">
      <article class="content-card">
        {tool.articleHtml && (
          <div class="tool-article" id="article-heading" set:html={tool.articleHtml} />
        )}

        {tool.howToUse.length > 0 && (
          <>
            <h2 id="how-to-use-heading">How to use the {tool.title.toLowerCase()}</h2>
            <ol>
              {tool.howToUse.map((step) => <li>{step}</li>)}
            </ol>
          </>
        )}

        {tool.howItWorks && (
          <>
            <h3 id="how-it-works-heading">How it works</h3>
            <p>{tool.howItWorks}</p>
          </>
        )}

        {tool.examples && tool.examples.length > 0 && (
          <>
            <h3 id="examples-heading">Examples</h3>
            <div class="formula-table-wrap">
              <table>
                <thead>
                  <tr><th scope="col">Input</th><th scope="col">Result</th></tr>
                </thead>
                <tbody>
                  {tool.examples.map((example) => (
                    <tr><td>{example.input}</td><td>{example.output}</td></tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        <FaqAccordion faqs={tool.faqs} />

        {related.length > 0 && (
          <>
            <h3 id="related-heading">Related tools</h3>
            <div class="cat-list">
              {related.map((r) => {
                const relatedCluster = getCluster(r.cluster);
                return (
                  <a class="cat-tool" href={`/${r.cluster}/${r.slug}/`}>
                    <div class="tool-ico" style={`--tool:${relatedCluster?.color};--tool-soft:${relatedCluster?.soft}`} set:html={icon(r.icon)} />
                    <div><h3>{r.title}</h3><p>{r.intro}</p></div>
                  </a>
                );
              })}
            </div>
          </>
        )}

        <slot name="footer-note" />
      </article>

      <aside class="toc">
        <b>On this page</b>
        {tocItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </aside>
    </div>
  </div>
</section>

<style>
  .formula-table-wrap {
    overflow-x: auto;
  }
  .formula-table-wrap table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .formula-table-wrap th,
  .formula-table-wrap td {
    text-align: left;
    padding: 10px;
    border-bottom: 1px solid var(--line);
  }
  .formula-table-wrap th {
    color: var(--muted);
    font-weight: 600;
  }
  .cat-tool h3 {
    text-decoration: none;
  }

  /* tool.articleHtml is injected via set:html, so Astro's scoped-style
     attribute never reaches its children — these rules must stay :global(). */
  .tool-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: var(--space-5) 0;
    overflow-x: auto;
    display: block;
  }
  .tool-article :global(th),
  .tool-article :global(td) {
    text-align: left;
    padding: 10px;
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }
  .tool-article :global(th) {
    color: var(--muted);
    font-weight: 600;
  }
  .tool-article :global(ul),
  .tool-article :global(ol) {
    padding-left: 1.3em;
  }
  .tool-article :global(a) {
    color: var(--brand);
    text-decoration: underline;
  }
  .tool-article :global(h2) {
    margin-top: var(--space-8);
  }
  .tool-article :global(h3) {
    margin-top: var(--space-6);
  }
</style>

<script>
  const shareBtn = document.getElementById('shareTool');
  shareBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(location.href);
      (window as any).__toolhubToast?.('Page link copied');
    } catch {
      // Clipboard API unavailable; silently ignore.
    }
  });
</script>
