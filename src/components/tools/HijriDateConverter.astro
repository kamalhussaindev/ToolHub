---
import Callout from '../Callout.astro';
---

<div class="calc-shell" id="hijri-converter">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Choose a direction</h2>
      <div class="form-grid">
        <div class="field">
          <label for="hijriDirection">Direction</label>
          <div class="input-wrap">
            <select id="hijriDirection" style="border:0;flex:1">
              <option value="g2h" selected>Gregorian → Hijri</option>
              <option value="h2g">Hijri → Gregorian</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Enter the date</h2>
      <div id="hijriG2hFields" class="form-grid">
        <div class="field">
          <label for="hijriGregDate">Gregorian date</label>
          <div class="input-wrap"><input id="hijriGregDate" type="date" /></div>
        </div>
      </div>
      <div id="hijriH2gFields" class="form-grid" hidden>
        <div class="field">
          <label for="hijriDay">Day</label>
          <div class="input-wrap"><input id="hijriDay" type="number" value="1" min="1" max="30" step="1" /></div>
        </div>
        <div class="field">
          <label for="hijriMonth">Month</label>
          <div class="input-wrap">
            <select id="hijriMonth" style="border:0;flex:1">
              <option value="1">1 — Muharram</option>
              <option value="2">2 — Safar</option>
              <option value="3">3 — Rabi' al-awwal</option>
              <option value="4">4 — Rabi' al-thani</option>
              <option value="5">5 — Jumada al-awwal</option>
              <option value="6">6 — Jumada al-thani</option>
              <option value="7">7 — Rajab</option>
              <option value="8">8 — Sha'ban</option>
              <option value="9">9 — Ramadan</option>
              <option value="10">10 — Shawwal</option>
              <option value="11">11 — Dhu al-Qi'dah</option>
              <option value="12">12 — Dhu al-Hijjah</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label for="hijriYear">Year (AH)</label>
          <div class="input-wrap"><input id="hijriYear" type="number" value="1447" min="1" step="1" /></div>
        </div>
      </div>
      <button class="calc-cta" id="hijriToday" type="button" style="margin-top:16px">Today</button>
    </div>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Converted date</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span id="hijriResultLabel">Hijri date</span><strong id="hijriResult" style="font-size:30px" aria-live="polite">—</strong></div>
    <p class="result-note" id="hijriError"></p>
    <Callout variant="note" title="Umm al-Qura calendar">
      <p>
        Because Islamic months can also begin with the local sighting of the moon, the actual
        date observed in your country may differ by about a day.
      </p>
    </Callout>
  </aside>
</div>

<script>
  const HIJRI_MONTH_NAMES = [
    "Muharram", 'Safar', "Rabi' al-awwal", "Rabi' al-thani", 'Jumada al-awwal',
    'Jumada al-thani', 'Rajab', "Sha'ban", 'Ramadan', 'Shawwal', "Dhu al-Qi'dah", 'Dhu al-Hijjah',
  ];

  const hijriPartsFormatter = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', {
    day: 'numeric',
    month: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });

  function getHijriParts(date: Date): { day: number; month: number; year: number } {
    const parts = hijriPartsFormatter.formatToParts(date);
    const day = Number(parts.find((p) => p.type === 'day')?.value);
    const month = Number(parts.find((p) => p.type === 'month')?.value);
    const year = Number(parts.find((p) => p.type === 'year')?.value);
    return { day, month, year };
  }

  function estimateGregorianFromHijri(hy: number, hm: number, hd: number): Date {
    const epoch = Date.UTC(622, 6, 19);
    const daysSinceEpoch = (hy - 1) * 354.367 + (hm - 1) * 29.5306 + (hd - 1);
    return new Date(epoch + Math.round(daysSinceEpoch) * 86400000);
  }

  function hijriToGregorian(hy: number, hm: number, hd: number): Date | null {
    const seed = estimateGregorianFromHijri(hy, hm, hd);
    for (let offset = -10; offset <= 10; offset++) {
      const candidate = new Date(seed.getTime() + offset * 86400000);
      const parts = getHijriParts(candidate);
      if (parts.day === hd && parts.month === hm && parts.year === hy) {
        return candidate;
      }
    }
    return null;
  }

  function formatGregorian(date: Date): string {
    return new Intl.DateTimeFormat('en-US', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' }).format(date);
  }

  function formatHijri(parts: { day: number; month: number; year: number }): string {
    return `${parts.day} ${HIJRI_MONTH_NAMES[parts.month - 1]} ${parts.year} AH`;
  }

  const root = document.getElementById('hijri-converter');
  if (root) {
    const directionSelect = root.querySelector<HTMLSelectElement>('#hijriDirection')!;
    const g2hFields = document.getElementById('hijriG2hFields')!;
    const h2gFields = document.getElementById('hijriH2gFields')!;
    const gregDateInput = root.querySelector<HTMLInputElement>('#hijriGregDate')!;
    const hDayInput = root.querySelector<HTMLInputElement>('#hijriDay')!;
    const hMonthSelect = root.querySelector<HTMLSelectElement>('#hijriMonth')!;
    const hYearInput = root.querySelector<HTMLInputElement>('#hijriYear')!;
    const todayBtn = document.getElementById('hijriToday')!;
    const errorEl = document.getElementById('hijriError')!;
    const resultValue = document.getElementById('hijriResult')!;
    const resultLabel = document.getElementById('hijriResultLabel')!;

    function todayUTC(): Date {
      const now = new Date();
      return new Date(Date.UTC(now.getFullYear(), now.getMonth(), now.getDate()));
    }

    function updateFieldVisibility() {
      const isG2h = directionSelect.value === 'g2h';
      g2hFields.hidden = !isG2h;
      h2gFields.hidden = isG2h;
      resultLabel.textContent = isG2h ? 'Hijri date' : 'Gregorian date';
    }

    function calculate() {
      const isG2h = directionSelect.value === 'g2h';

      if (isG2h) {
        if (!gregDateInput.value) {
          errorEl.textContent = 'Please choose a Gregorian date.';
          resultValue.textContent = '—';
          return;
        }
        const [y, m, d] = gregDateInput.value.split('-').map(Number);
        const date = new Date(Date.UTC(y, m - 1, d));
        errorEl.textContent = '';
        resultValue.textContent = formatHijri(getHijriParts(date));
      } else {
        const day = parseInt(hDayInput.value, 10);
        const month = parseInt(hMonthSelect.value, 10);
        const year = parseInt(hYearInput.value, 10);

        if (Number.isNaN(day) || day < 1 || day > 30 || Number.isNaN(year) || year < 1) {
          errorEl.textContent = 'Please enter a valid Hijri day (1–30) and year.';
          resultValue.textContent = '—';
          return;
        }

        const gregorian = hijriToGregorian(year, month, day);
        if (!gregorian) {
          errorEl.textContent = "Couldn't match that date — check the day is valid for that Hijri month.";
          resultValue.textContent = '—';
          return;
        }
        errorEl.textContent = '';
        resultValue.textContent = formatGregorian(gregorian);
      }
    }

    directionSelect.addEventListener('change', () => {
      updateFieldVisibility();
      calculate();
    });
    gregDateInput.addEventListener('input', calculate);
    [hDayInput, hMonthSelect, hYearInput].forEach((el) => el.addEventListener('input', calculate));

    todayBtn.addEventListener('click', () => {
      const today = todayUTC();
      if (directionSelect.value === 'g2h') {
        const y = today.getUTCFullYear();
        const m = String(today.getUTCMonth() + 1).padStart(2, '0');
        const d = String(today.getUTCDate()).padStart(2, '0');
        gregDateInput.value = `${y}-${m}-${d}`;
      } else {
        const parts = getHijriParts(today);
        hDayInput.value = String(parts.day);
        hMonthSelect.value = String(parts.month);
        hYearInput.value = String(parts.year);
      }
      calculate();
    });

    updateFieldVisibility();
    todayBtn.click();
  }
</script>
