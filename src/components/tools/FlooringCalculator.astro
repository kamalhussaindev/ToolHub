---
import CalcShell from '../CalcShell.astro';
---

<div class="calc-shell" id="flooring-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Room dimensions</h2>
      <div class="form-grid">
        <div class="field">
          <label for="floorLength">Room length <span data-unit-length>(m)</span></label>
          <div class="input-wrap"><input id="floorLength" type="number" value="5" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="floorWidth">Room width <span data-unit-length>(m)</span></label>
          <div class="input-wrap"><input id="floorWidth" type="number" value="4" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="floorUnit">Units</label>
          <div class="input-wrap"><select id="floorUnit" style="border:0;flex:1"><option value="metric">Metric</option><option value="imperial">Imperial</option></select></div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Flooring &amp; waste</h2>
      <div class="form-grid">
        <div class="field">
          <label for="floorCoverage">Coverage per box <span data-unit-area>(m²)</span></label>
          <div class="input-wrap"><input id="floorCoverage" type="number" value="2.2" min="0.01" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="floorWaste">Waste allowance (%)</label>
          <div class="input-wrap"><input id="floorWaste" type="number" value="10" min="0" max="50" step="1" /></div>
        </div>
      </div>
    </div>

    <button class="calc-cta" id="calculateFloor" type="button">Calculate flooring</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Flooring needed</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Boxes to buy</span><strong id="floorBoxes" aria-live="polite">10</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Room area</span><b id="floorRoomArea">20.00 m²</b></div>
      <div class="result-stat"><span>Total with waste</span><b id="floorTotalArea">22.00 m²</b></div>
    </div>
    <p class="result-note">Boxes are rounded up — you can only buy whole boxes.</p>
  </aside>
</div>

<CalcShell label="Boxes to buy" valueSelector="#floorBoxes" />

<script>
  const root = document.getElementById('flooring-calculator');
  if (root) {
    const v = (id: string) => parseFloat((root.querySelector(`#${id}`) as HTMLInputElement).value) || 0;
    const unitSelect = root.querySelector<HTMLSelectElement>('#floorUnit')!;
    const lengthLabels = root.querySelectorAll<HTMLElement>('[data-unit-length]');
    const areaLabels = root.querySelectorAll<HTMLElement>('[data-unit-area]');

    function updateUnitLabels() {
      const metric = unitSelect.value === 'metric';
      lengthLabels.forEach((el) => (el.textContent = metric ? '(m)' : '(ft)'));
      areaLabels.forEach((el) => (el.textContent = metric ? '(m²)' : '(ft²)'));
    }

    function calculate() {
      const metric = unitSelect.value === 'metric';
      const length = v('floorLength');
      const width = v('floorWidth');
      const coverage = Math.max(0.01, v('floorCoverage'));
      const waste = v('floorWaste');

      const roomArea = length * width;
      const totalArea = roomArea * (1 + waste / 100);
      const boxes = Math.ceil(Math.round((totalArea / coverage) * 1e6) / 1e6);
      const unitLabel = metric ? 'm²' : 'ft²';

      document.getElementById('floorBoxes')!.textContent = boxes.toLocaleString();
      document.getElementById('floorRoomArea')!.textContent = `${roomArea.toFixed(2)} ${unitLabel}`;
      document.getElementById('floorTotalArea')!.textContent = `${totalArea.toFixed(2)} ${unitLabel}`;
    }

    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', calculate));
    unitSelect.addEventListener('change', () => {
      updateUnitLabels();
      calculate();
    });
    document.getElementById('calculateFloor')?.addEventListener('click', calculate);

    updateUnitLabels();
    calculate();
  }
</script>
