---
import Callout from '../Callout.astro';
---

<div class="calc-shell" id="abv-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Gravity readings</h2>
      <div class="form-grid">
        <div class="field">
          <label for="abvOg">Original Gravity (OG)</label>
          <div class="input-wrap"><input id="abvOg" type="number" inputmode="decimal" min="0.98" max="1.2" step="0.001" placeholder="e.g. 1.055" /></div>
        </div>
        <div class="field">
          <label for="abvFg">Final Gravity (FG)</label>
          <div class="input-wrap"><input id="abvFg" type="number" inputmode="decimal" min="0.98" max="1.2" step="0.001" placeholder="e.g. 1.012" /></div>
        </div>
      </div>
      <p class="field-hint" id="abvHint" role="alert" aria-live="polite"></p>
    </div>

    <Callout variant="note" title="Take readings at the right temperature">
      <p>Hydrometers are calibrated to a set temperature — correct off-temperature readings before entering them here for an accurate result.</p>
    </Callout>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>ABV</h2><span class="status">Live</span></div>
    <div class="primary-result">
      <span id="abvResultLabel">Enter OG and FG to see your ABV</span>
      <strong id="abvResultValue" aria-live="polite">—</strong>
    </div>
    <button class="calc-cta" id="abvCopy" type="button">Copy result</button>
  </aside>
</div>

<style>
  .field-hint {
    min-height: 16px;
    margin: 10px 2px 0;
    font-size: 11.5px;
    color: var(--color-error, #dc2626);
  }
</style>

<script>
  const root = document.getElementById('abv-calculator');
  if (root) {
    const ogInput = root.querySelector<HTMLInputElement>('#abvOg')!;
    const fgInput = root.querySelector<HTMLInputElement>('#abvFg')!;
    const hint = root.querySelector<HTMLElement>('#abvHint')!;
    const resultLabel = document.getElementById('abvResultLabel')!;
    const resultValue = document.getElementById('abvResultValue')!;
    const copyBtn = document.getElementById('abvCopy') as HTMLButtonElement;

    function calculate() {
      hint.textContent = '';
      const ogRaw = ogInput.value.trim();
      const fgRaw = fgInput.value.trim();

      if (ogRaw === '' || fgRaw === '') {
        resultLabel.textContent = 'Enter OG and FG to see your ABV';
        resultValue.textContent = '—';
        return;
      }

      const og = parseFloat(ogRaw);
      const fg = parseFloat(fgRaw);

      if (Number.isNaN(og) || Number.isNaN(fg)) {
        hint.textContent = 'Enter valid numbers.';
        resultLabel.textContent = 'Enter OG and FG to see your ABV';
        resultValue.textContent = '—';
        return;
      }
      if (og < 0.98 || og > 1.2 || fg < 0.98 || fg > 1.2) {
        hint.textContent = 'Gravity readings are usually between 0.980 and 1.200.';
        resultLabel.textContent = 'Enter OG and FG to see your ABV';
        resultValue.textContent = '—';
        return;
      }
      if (fg > og) {
        hint.textContent = 'Final gravity is higher than original gravity — check you haven\'t swapped them.';
        resultLabel.textContent = 'Enter OG and FG to see your ABV';
        resultValue.textContent = '—';
        return;
      }

      const abv = Math.max(0, Math.round((og - fg) * 131.25 * 10) / 10);
      resultValue.textContent = `${abv.toFixed(1)}%`;
      resultLabel.textContent = `OG ${og.toFixed(3)} − FG ${fg.toFixed(3)} = ${abv.toFixed(1)}% ABV`;
    }

    ogInput.addEventListener('input', calculate);
    fgInput.addEventListener('input', calculate);

    copyBtn.addEventListener('click', async () => {
      const value = resultValue.textContent ?? '';
      if (!value || value === '—') return;
      try {
        await navigator.clipboard.writeText(value);
        copyBtn.textContent = 'Copied!';
        setTimeout(() => (copyBtn.textContent = 'Copy result'), 1500);
      } catch {
        // Clipboard API unavailable; silently ignore.
      }
    });

    calculate();
  }
</script>
