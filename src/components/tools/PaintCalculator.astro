---
import ResultPanel from '../ResultPanel.astro';
---

<div class="calc" id="paint-calculator">
  <div class="calc__field-row">
    <div class="field">
      <label for="paint-unit">Units</label>
      <select id="paint-unit">
        <option value="metric">Metric (m, m², litres)</option>
        <option value="imperial">Imperial (ft, ft², gallons)</option>
      </select>
    </div>
  </div>

  <div class="calc__field-row">
    <div class="field">
      <label for="paint-perimeter">Wall perimeter <span data-unit-length>(m)</span></label>
      <input id="paint-perimeter" type="number" inputmode="decimal" min="0" step="0.1" value="14" />
      <span class="hint">Sum of the lengths of all walls you're painting.</span>
    </div>
    <div class="field">
      <label for="paint-height">Wall height <span data-unit-length>(m)</span></label>
      <input id="paint-height" type="number" inputmode="decimal" min="0" step="0.1" value="2.4" />
    </div>
  </div>

  <div class="calc__field-row">
    <div class="field">
      <label for="paint-openings">Doors &amp; windows area <span data-unit-area>(m²)</span></label>
      <input id="paint-openings" type="number" inputmode="decimal" min="0" step="0.1" value="3" />
    </div>
    <div class="field">
      <label for="paint-coats">Number of coats</label>
      <input id="paint-coats" type="number" inputmode="numeric" min="1" step="1" value="2" />
    </div>
  </div>

  <div class="field">
    <label for="paint-coverage">Paint coverage <span data-unit-coverage>(m² per litre)</span></label>
    <input id="paint-coverage" type="number" inputmode="decimal" min="0.1" step="0.1" value="10" />
    <span class="hint">Check the tin — most interior emulsion covers 10–12 m² per litre (350–400 ft² per gallon).</span>
  </div>

  <p class="calc__error" id="paint-error" role="alert" hidden></p>

  <ResultPanel id="paint-result" label="Paint needed">
    <span id="paint-result-volume">—</span>
    <span class="calc__result-sub" id="paint-result-area"></span>
  </ResultPanel>

  <div class="calc__actions">
    <button type="button" class="btn btn-secondary" id="paint-copy">Copy result</button>
    <button type="button" class="btn btn-secondary" id="paint-reset">Reset</button>
  </div>
</div>

<style>
  .calc__field-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-4);
  }
  .calc__error {
    color: var(--color-error);
    font-size: var(--text-sm);
    font-weight: 600;
  }
  .calc__result-sub {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }
  .calc__actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
</style>

<script>
  const root = document.getElementById('paint-calculator');
  if (root) {
    const unitSelect = root.querySelector<HTMLSelectElement>('#paint-unit')!;
    const perimeter = root.querySelector<HTMLInputElement>('#paint-perimeter')!;
    const height = root.querySelector<HTMLInputElement>('#paint-height')!;
    const openings = root.querySelector<HTMLInputElement>('#paint-openings')!;
    const coats = root.querySelector<HTMLInputElement>('#paint-coats')!;
    const coverage = root.querySelector<HTMLInputElement>('#paint-coverage')!;
    const errorEl = root.querySelector<HTMLParagraphElement>('#paint-error')!;
    const resultVolume = root.querySelector<HTMLSpanElement>('#paint-result-volume')!;
    const resultArea = root.querySelector<HTMLSpanElement>('#paint-result-area')!;
    const copyBtn = root.querySelector<HTMLButtonElement>('#paint-copy')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('#paint-reset')!;
    const lengthLabels = root.querySelectorAll<HTMLElement>('[data-unit-length]');
    const areaLabels = root.querySelectorAll<HTMLElement>('[data-unit-area]');
    const coverageLabels = root.querySelectorAll<HTMLElement>('[data-unit-coverage]');

    const defaults: Record<string, string> = {
      'paint-perimeter': '14',
      'paint-height': '2.4',
      'paint-openings': '3',
      'paint-coats': '2',
      'paint-coverage': '10',
    };

    function updateUnitLabels() {
      const metric = unitSelect.value === 'metric';
      lengthLabels.forEach((el) => (el.textContent = metric ? '(m)' : '(ft)'));
      areaLabels.forEach((el) => (el.textContent = metric ? '(m²)' : '(ft²)'));
      coverageLabels.forEach((el) => (el.textContent = metric ? '(m² per litre)' : '(ft² per gallon)'));
    }

    function calculate() {
      const metric = unitSelect.value === 'metric';
      const p = parseFloat(perimeter.value);
      const h = parseFloat(height.value);
      const o = parseFloat(openings.value);
      const c = parseFloat(coats.value);
      const cov = parseFloat(coverage.value);

      const values = [p, h, o, c, cov];
      if (values.some((v) => Number.isNaN(v) || v < 0) || cov <= 0 || c <= 0) {
        errorEl.textContent = 'Please enter valid, positive numbers in every field.';
        errorEl.hidden = false;
        resultVolume.textContent = '—';
        resultArea.textContent = '';
        return;
      }

      const grossArea = p * h;
      const netArea = Math.max(grossArea - o, 0);
      if (netArea <= 0) {
        errorEl.textContent = 'Doors & windows area can\'t exceed the total wall area.';
        errorEl.hidden = false;
        resultVolume.textContent = '—';
        resultArea.textContent = '';
        return;
      }
      errorEl.hidden = true;

      const volume = (netArea * c) / cov;
      const unitLabel = metric ? 'litres' : 'gallons';
      const areaLabel = metric ? 'm²' : 'ft²';
      resultVolume.textContent = `${volume.toFixed(1)} ${unitLabel}`;
      resultArea.textContent = `${netArea.toFixed(1)} ${areaLabel} net paintable area, ${c} coat${c === 1 ? '' : 's'}`;
    }

    [perimeter, height, openings, coats, coverage].forEach((input) => {
      input.addEventListener('input', calculate);
    });
    unitSelect.addEventListener('change', () => {
      updateUnitLabels();
      calculate();
    });

    copyBtn.addEventListener('click', async () => {
      const text = `${resultVolume.textContent} — ${resultArea.textContent}`;
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = 'Copied!';
        setTimeout(() => (copyBtn.textContent = 'Copy result'), 1500);
      } catch {
        // Clipboard API unavailable; silently ignore.
      }
    });

    resetBtn.addEventListener('click', () => {
      unitSelect.value = 'metric';
      Object.entries(defaults).forEach(([id, value]) => {
        const el = root.querySelector<HTMLInputElement>(`#${id}`);
        if (el) el.value = value;
      });
      updateUnitLabels();
      calculate();
    });

    updateUnitLabels();
    calculate();
  }
</script>
