---
import CalcShell from '../CalcShell.astro';
---

<div class="calc-shell" id="paint-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Wall dimensions</h2>
      <div class="form-grid">
        <div class="field">
          <label for="paintPerimeter">Wall perimeter <span data-unit-length>(m)</span></label>
          <div class="input-wrap"><input id="paintPerimeter" type="number" value="14" min="0" step="0.1" /></div>
        </div>
        <div class="field">
          <label for="paintHeight">Wall height <span data-unit-length>(m)</span></label>
          <div class="input-wrap"><input id="paintHeight" type="number" value="2.4" min="0" step="0.1" /></div>
        </div>
        <div class="field">
          <label for="paintUnit">Units</label>
          <div class="input-wrap"><select id="paintUnit" style="border:0;flex:1"><option value="metric">Metric</option><option value="imperial">Imperial</option></select></div>
        </div>
        <div class="field">
          <label for="paintOpenings">Doors &amp; windows area <span data-unit-area>(m²)</span></label>
          <div class="input-wrap"><input id="paintOpenings" type="number" value="3" min="0" step="0.1" /></div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Coverage &amp; coats</h2>
      <div class="form-grid">
        <div class="field">
          <label for="paintCoats">Number of coats</label>
          <div class="input-wrap"><input id="paintCoats" type="number" value="2" min="1" step="1" /></div>
        </div>
        <div class="field">
          <label for="paintCoverage">Coverage <span data-unit-coverage>(m² per litre)</span></label>
          <div class="input-wrap"><input id="paintCoverage" type="number" value="10" min="0.1" step="0.1" /></div>
        </div>
      </div>
    </div>

    <button class="calc-cta" id="calculatePaint" type="button">Calculate paint</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Paint needed</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Volume required</span><strong id="paintVolume" aria-live="polite">6.1 litres</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Net paintable area</span><b id="paintArea">30.6 m²</b></div>
      <div class="result-stat"><span>Coats</span><b id="paintCoatsResult">2</b></div>
    </div>
    <p class="result-note" id="paintNote">Check the tin — most interior emulsion covers 10–12 m² per litre (350–400 ft² per gallon).</p>
  </aside>
</div>

<CalcShell label="Paint needed" valueSelector="#paintVolume" />

<script>
  const root = document.getElementById('paint-calculator');
  if (root) {
    const v = (id: string) => parseFloat((root.querySelector(`#${id}`) as HTMLInputElement).value) || 0;
    const unitSelect = root.querySelector<HTMLSelectElement>('#paintUnit')!;
    const lengthLabels = root.querySelectorAll<HTMLElement>('[data-unit-length]');
    const areaLabels = root.querySelectorAll<HTMLElement>('[data-unit-area]');
    const coverageLabels = root.querySelectorAll<HTMLElement>('[data-unit-coverage]');
    const noteEl = document.getElementById('paintNote')!;

    function updateUnitLabels() {
      const metric = unitSelect.value === 'metric';
      lengthLabels.forEach((el) => (el.textContent = metric ? '(m)' : '(ft)'));
      areaLabels.forEach((el) => (el.textContent = metric ? '(m²)' : '(ft²)'));
      coverageLabels.forEach((el) => (el.textContent = metric ? '(m² per litre)' : '(ft² per gallon)'));
    }

    function calculate() {
      const metric = unitSelect.value === 'metric';
      const perimeter = v('paintPerimeter');
      const height = v('paintHeight');
      const openings = v('paintOpenings');
      const coats = Math.max(1, v('paintCoats'));
      const coverage = Math.max(0.1, v('paintCoverage'));

      const grossArea = perimeter * height;
      const netArea = Math.max(grossArea - openings, 0);
      const volume = (netArea * coats) / coverage;
      const unitLabel = metric ? 'litres' : 'gallons';
      const areaLabel = metric ? 'm²' : 'ft²';

      document.getElementById('paintVolume')!.textContent = `${volume.toFixed(1)} ${unitLabel}`;
      document.getElementById('paintArea')!.textContent = `${netArea.toFixed(1)} ${areaLabel}`;
      document.getElementById('paintCoatsResult')!.textContent = String(coats);
      noteEl.textContent = metric
        ? 'Check the tin — most interior emulsion covers 10–12 m² per litre.'
        : 'Check the tin — most interior emulsion covers 350–400 ft² per gallon.';
    }

    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', calculate));
    unitSelect.addEventListener('change', () => {
      updateUnitLabels();
      calculate();
    });
    document.getElementById('calculatePaint')?.addEventListener('click', calculate);

    updateUnitLabels();
    calculate();
  }
</script>
