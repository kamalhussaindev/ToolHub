---
import CalcShell from '../CalcShell.astro';
import Callout from '../Callout.astro';
---

<div class="calc-shell" id="zakat-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Zakatable assets</h2>
      <div class="form-grid">
        <div class="field">
          <label for="zCurrency">Currency label</label>
          <div class="input-wrap"><input id="zCurrency" type="text" maxlength="8" value="$" /></div>
        </div>
        <div class="field">
          <label for="zCash">Cash in hand</label>
          <div class="input-wrap"><input id="zCash" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zBank">Bank balances &amp; savings</label>
          <div class="input-wrap"><input id="zBank" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zGold">Gold value</label>
          <div class="input-wrap"><input id="zGold" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zSilver">Silver value</label>
          <div class="input-wrap"><input id="zSilver" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zBusiness">Business / merchandise inventory</label>
          <div class="input-wrap"><input id="zBusiness" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zReceivables">Money owed to you (likely repaid)</label>
          <div class="input-wrap"><input id="zReceivables" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zInvestments">Other investments (zakatable portion)</label>
          <div class="input-wrap"><input id="zInvestments" type="number" value="0" min="0" step="1" /></div>
        </div>
      </div>
      <p class="result-note">Use the <a href="/islamic/zakat-on-gold/">Zakat on Gold Calculator</a> to work out the gold value above by weight and karat.</p>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Liabilities</h2>
      <div class="form-grid">
        <div class="field">
          <label for="zDebts">Immediate debts &amp; bills due</label>
          <div class="input-wrap"><input id="zDebts" type="number" value="0" min="0" step="1" /></div>
        </div>
        <div class="field">
          <label for="zShortterm">Other short-term liabilities</label>
          <div class="input-wrap"><input id="zShortterm" type="number" value="0" min="0" step="1" /></div>
        </div>
      </div>
      <Callout variant="note" title="What to deduct">
        <p>
          Your primary residence and personal-use items are never zakatable. For a mortgage or
          long-term loan, generally only the amount currently due is deducted — not the full
          remaining balance (scholarly views differ on this point).
        </p>
      </Callout>
    </div>

    <div class="calc-block">
      <h2><span class="step">3</span>Nisab basis</h2>
      <div class="form-grid">
        <div class="field">
          <label for="zBasis">Calculate nisab using</label>
          <div class="input-wrap">
            <select id="zBasis" style="border:0;flex:1">
              <option value="silver" selected>Silver (595 g) — recommended</option>
              <option value="gold">Gold (85 g)</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label for="zPrice">Price per gram <span id="zPriceMetal">(silver)</span></label>
          <div class="input-wrap"><input id="zPrice" type="number" value="0.90" min="0" step="0.01" /></div>
        </div>
      </div>
      <Callout variant="info" title="Which nisab should I use?">
        <p>
          Many contemporary scholars and zakat institutions recommend the silver basis because its
          lower threshold benefits recipients. Both are valid — this tool defaults to silver.
        </p>
      </Callout>
    </div>

    <button class="calc-cta" id="calculateZakat" type="button">Calculate zakat</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Zakat due (2.5%)</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Amount due</span><strong id="zDue" aria-live="polite">$0</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Net zakatable wealth</span><b id="zNetWealth">$0.00</b></div>
      <div class="result-stat"><span>Nisab used</span><b id="zNisabUsed">$535.50</b></div>
    </div>
    <p class="result-note" id="zNote"></p>
    <Callout variant="note" title="Tracking your zakat year (hawl)">
      <p>
        Zakat is due on wealth held for one lunar (Hijri) year. Use our
        <a href="/islamic/hijri-date-converter/">Hijri Date Converter</a> to track your anniversary.
      </p>
    </Callout>
  </aside>
</div>

<CalcShell label="Zakat due" valueSelector="#zDue" />

<script>
  import { NISAB_GOLD_GRAMS, NISAB_SILVER_GRAMS, ZAKAT_RATE } from '../../data/islamic';

  const root = document.getElementById('zakat-calculator');
  if (root) {
    const assetIds = ['zCash', 'zBank', 'zGold', 'zSilver', 'zBusiness', 'zReceivables', 'zInvestments'];
    const liabilityIds = ['zDebts', 'zShortterm'];
    const currencyInput = root.querySelector<HTMLInputElement>('#zCurrency')!;
    const basisSelect = root.querySelector<HTMLSelectElement>('#zBasis')!;
    const priceInput = root.querySelector<HTMLInputElement>('#zPrice')!;
    const priceMetalLabel = document.getElementById('zPriceMetal')!;

    function num(id: string): number {
      const el = root!.querySelector<HTMLInputElement>(`#${id}`);
      const v = parseFloat(el?.value ?? '');
      return Number.isNaN(v) || v < 0 ? 0 : v;
    }

    function updateMetalLabel() {
      priceMetalLabel.textContent = basisSelect.value === 'silver' ? '(silver)' : '(gold)';
    }

    function calculate() {
      const currency = currencyInput.value.trim() || '$';
      const assets = assetIds.reduce((sum, id) => sum + num(id), 0);
      const liabilities = liabilityIds.reduce((sum, id) => sum + num(id), 0);
      const price = Math.max(0, parseFloat(priceInput.value) || 0);
      const netWealth = assets - liabilities;
      const nisabGrams = basisSelect.value === 'silver' ? NISAB_SILVER_GRAMS : NISAB_GOLD_GRAMS;
      const nisabThreshold = nisabGrams * price;

      document.getElementById('zNetWealth')!.textContent = `${currency}${netWealth.toFixed(2)}`;
      document.getElementById('zNisabUsed')!.textContent = `${currency}${nisabThreshold.toFixed(2)}`;
      const note = document.getElementById('zNote')!;

      if (!price) {
        document.getElementById('zDue')!.textContent = `${currency}0`;
        note.textContent = 'Enter the current price per gram to calculate your nisab threshold.';
        return;
      }

      if (netWealth < nisabThreshold) {
        const shortfall = nisabThreshold - netWealth;
        document.getElementById('zDue')!.textContent = `${currency}0`;
        note.textContent = `Below the ${basisSelect.value} nisab by ${currency}${shortfall.toFixed(2)} — no zakat is due this year.`;
        return;
      }

      const zakatDue = netWealth * ZAKAT_RATE;
      document.getElementById('zDue')!.textContent = `${currency}${zakatDue.toFixed(2)}`;
      note.textContent = `Above the ${basisSelect.value} nisab — 2.5% of net zakatable wealth is due.`;
    }

    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', calculate));
    basisSelect.addEventListener('change', () => {
      updateMetalLabel();
      calculate();
    });
    document.getElementById('calculateZakat')?.addEventListener('click', calculate);

    updateMetalLabel();
    calculate();
  }
</script>
