---
import Callout from '../Callout.astro';
import AdSlot from '../AdSlot.astro';

export interface Props {
  targetKb: number;
  targetLabel: string; // e.g. "20 KB" or "1 MB"
  adSlot: string;
}

const { targetKb, targetLabel, adSlot } = Astro.props;
---

<div class="calc-shell" id="fixed-target-tool" data-target-kb={targetKb} data-target-label={targetLabel}>
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Upload your image</h2>
      <label class="upload-zone" for="imageInput" id="uploadZone">
        <input type="file" id="imageInput" accept="image/jpeg,image/png,image/webp" class="visually-hidden" />
        <div class="upload-empty" id="uploadEmpty">
          <span class="upload-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 16V4M7 9l5-5 5 5" />
              <path d="M4 16v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3" />
            </svg>
          </span>
          <p><strong>Click to upload</strong> or drag and drop</p>
          <small>JPG, PNG or WebP</small>
        </div>
        <div class="upload-preview" id="uploadPreview" hidden>
          <img id="previewImg" alt="Selected image preview" />
          <div class="upload-meta">
            <b id="previewName"></b>
            <span id="previewSize"></span>
          </div>
          <small>Click to choose a different image</small>
        </div>
      </label>
      <p class="field-hint" id="uploadHint" role="alert" aria-live="polite"></p>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Target size</h2>
      <div class="target-badge">
        This tool compresses straight to <b>{targetLabel}</b> or below — no other settings needed.
      </div>
    </div>

    <button class="calc-cta" id="compressBtn" type="button" disabled>Compress to {targetLabel}</button>

    <Callout variant="info" title="Your image never leaves your device">
      <p>
        Compression runs entirely in your browser using the Canvas API — nothing is uploaded to a
        server, which matters if you're compressing a passport photo, ID, or certificate.
      </p>
    </Callout>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Result</h2><span class="status" id="resultStatus">Waiting</span></div>
    <div class="primary-result">
      <span id="resultLabel">Upload an image to get started</span>
      <strong id="resultValue" aria-live="polite">—</strong>
    </div>
    <div class="result-grid">
      <div class="result-stat"><span>Original</span><b id="statOriginal">—</b></div>
      <div class="result-stat"><span>Compressed</span><b id="statCompressed">—</b></div>
    </div>
    <img id="resultPreview" class="result-preview" alt="Compressed image preview" hidden />
    <p class="result-note" id="resultNote"></p>
    <a class="calc-cta" id="downloadBtn" download="compressed.jpg" hidden>Download compressed image</a>
    <AdSlot slot={adSlot} variant="sidebar" />
  </aside>
</div>

<style>
  .upload-zone {
    display: block;
    border: 1.5px dashed var(--line-strong);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    cursor: pointer;
    transition: 0.16s;
  }
  .upload-zone:hover,
  .upload-zone.is-dragover {
    border-color: var(--brand);
    background: var(--brand-soft);
  }
  .upload-zone:has(input:focus-visible) {
    box-shadow: 0 0 0 3px rgba(83, 104, 243, 0.18);
  }
  .upload-ico {
    display: inline-flex;
    width: 34px;
    height: 34px;
    color: var(--brand);
    margin-bottom: 8px;
  }
  .upload-empty p {
    margin: 0 0 2px;
    font-size: 13.5px;
    color: var(--ink);
  }
  .upload-empty small {
    color: var(--muted);
    font-size: 11.5px;
  }
  .upload-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .upload-preview img {
    max-width: 100%;
    max-height: 160px;
    border-radius: 8px;
    object-fit: contain;
  }
  .upload-meta b {
    display: block;
    font-size: 13px;
    word-break: break-all;
  }
  .upload-meta span {
    font-size: 11.5px;
    color: var(--muted);
  }
  .upload-preview small {
    color: var(--muted);
    font-size: 11px;
  }
  .field-hint {
    min-height: 16px;
    margin: 6px 2px 0;
    font-size: 11.5px;
    color: var(--color-error, #dc2626);
  }
  .target-badge {
    border: 1px solid var(--line-strong);
    background: var(--brand-soft);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 13px;
    color: var(--ink);
  }
  .target-badge b {
    color: var(--brand);
  }
  .calc-cta:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .result-preview {
    width: 100%;
    max-height: 180px;
    object-fit: contain;
    border-radius: 10px;
    border: 1px solid var(--line);
    margin-top: 12px;
    background: var(--canvas);
  }
  a.calc-cta {
    display: block;
    text-align: center;
    text-decoration: none;
    margin-top: 12px;
  }
</style>

<script>
  import { formatBytes, compressToTarget, isSupportedImage } from '../../lib/imageCompress';

  const root = document.getElementById('fixed-target-tool');
  if (root) {
    const targetKb = parseFloat(root.dataset.targetKb ?? '200');
    const targetLabel = root.dataset.targetLabel ?? `${targetKb} KB`;
    const targetBytes = targetKb * 1024;

    const uploadZone = document.getElementById('uploadZone')!;
    const imageInput = document.getElementById('imageInput') as HTMLInputElement;
    const uploadEmpty = document.getElementById('uploadEmpty')!;
    const uploadPreview = document.getElementById('uploadPreview')!;
    const previewImg = document.getElementById('previewImg') as HTMLImageElement;
    const previewName = document.getElementById('previewName')!;
    const previewSize = document.getElementById('previewSize')!;
    const uploadHint = document.getElementById('uploadHint')!;
    const compressBtn = document.getElementById('compressBtn') as HTMLButtonElement;
    const resultStatus = document.getElementById('resultStatus')!;
    const resultLabel = document.getElementById('resultLabel')!;
    const resultValue = document.getElementById('resultValue')!;
    const statOriginal = document.getElementById('statOriginal')!;
    const statCompressed = document.getElementById('statCompressed')!;
    const resultPreview = document.getElementById('resultPreview') as HTMLImageElement;
    const resultNote = document.getElementById('resultNote')!;
    const downloadBtn = document.getElementById('downloadBtn') as HTMLAnchorElement;

    let selectedFile: File | null = null;
    let lastObjectUrl: string | null = null;
    let isProcessing = false;

    function acceptFile(file: File | undefined | null) {
      uploadHint.textContent = '';
      if (!file) return;
      if (!isSupportedImage(file)) {
        uploadHint.textContent = 'Please choose a JPG, PNG, or WebP image.';
        return;
      }
      selectedFile = file;
      compressBtn.disabled = false;

      const url = URL.createObjectURL(file);
      previewImg.src = url;
      previewName.textContent = file.name;
      previewSize.textContent = formatBytes(file.size);
      uploadEmpty.hidden = true;
      uploadPreview.hidden = false;

      resetResult();
      runCompression();
    }

    imageInput.addEventListener('change', () => acceptFile(imageInput.files?.[0]));

    ['dragenter', 'dragover'].forEach((evt) =>
      uploadZone.addEventListener(evt, (e) => {
        e.preventDefault();
        uploadZone.classList.add('is-dragover');
      })
    );
    ['dragleave', 'drop'].forEach((evt) =>
      uploadZone.addEventListener(evt, (e) => {
        e.preventDefault();
        uploadZone.classList.remove('is-dragover');
      })
    );
    uploadZone.addEventListener('drop', (e) => {
      const file = (e as DragEvent).dataTransfer?.files?.[0];
      acceptFile(file);
    });

    compressBtn.addEventListener('click', () => runCompression());

    function resetResult() {
      resultStatus.textContent = 'Waiting';
      resultLabel.textContent = 'Upload an image to get started';
      resultValue.textContent = '—';
      statOriginal.textContent = '—';
      statCompressed.textContent = '—';
      resultPreview.hidden = true;
      resultNote.textContent = '';
      downloadBtn.hidden = true;
    }

    function showResult(originalBytes: number, finalBytes: number, url: string, isOriginal: boolean) {
      const reduction = originalBytes > 0 ? Math.round((1 - finalBytes / originalBytes) * 100) : 0;
      resultLabel.textContent = isOriginal ? 'No compression needed' : `Reduced by ${Math.max(0, reduction)}%`;
      resultValue.textContent = formatBytes(finalBytes);
      statOriginal.textContent = formatBytes(originalBytes);
      statCompressed.textContent = formatBytes(finalBytes);
      resultPreview.src = url;
      resultPreview.hidden = false;
      downloadBtn.href = url;
      downloadBtn.download = 'compressed.jpg';
      downloadBtn.hidden = false;
    }

    async function runCompression() {
      if (!selectedFile || isProcessing) return;
      isProcessing = true;
      compressBtn.disabled = true;
      resultStatus.textContent = 'Compressing…';
      resultLabel.textContent = `Compressing to fit ${targetLabel}…`;

      try {
        if (selectedFile.size <= targetBytes) {
          const url = URL.createObjectURL(selectedFile);
          showResult(selectedFile.size, selectedFile.size, url, true);
          resultStatus.textContent = 'Already small enough';
          resultNote.textContent = `Your image is already under ${targetLabel} — no compression needed.`;
        } else {
          const { blob, reachedTarget } = await compressToTarget(selectedFile, targetBytes);
          if (lastObjectUrl) URL.revokeObjectURL(lastObjectUrl);
          const url = URL.createObjectURL(blob);
          lastObjectUrl = url;
          showResult(selectedFile.size, blob.size, url, false);
          resultStatus.textContent = reachedTarget ? 'Done' : 'Best effort';
          resultNote.textContent = reachedTarget
            ? ''
            : `Couldn't fully reach ${targetLabel} without shrinking the image too much — this is the smallest clean result we could produce.`;
        }
      } catch {
        resultStatus.textContent = 'Error';
        resultLabel.textContent = 'Something went wrong reading that image — try a different file.';
      } finally {
        isProcessing = false;
        compressBtn.disabled = false;
      }
    }
  }
</script>
