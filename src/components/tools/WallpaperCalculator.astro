---
import CalcShell from '../CalcShell.astro';
---

<div class="calc-shell" id="wallpaper-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Wall dimensions</h2>
      <div class="form-grid">
        <div class="field">
          <label for="wpWallLength">Wall length <span data-unit-big>(m)</span></label>
          <div class="input-wrap"><input id="wpWallLength" type="number" value="10" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="wpWallHeight">Wall height <span data-unit-big>(m)</span></label>
          <div class="input-wrap"><input id="wpWallHeight" type="number" value="2.4" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="wpUnit">Units</label>
          <div class="input-wrap"><select id="wpUnit" style="border:0;flex:1"><option value="metric">Metric (m / cm)</option><option value="imperial">Imperial (ft / in)</option></select></div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Roll &amp; pattern</h2>
      <div class="form-grid">
        <div class="field">
          <label for="wpRollLength">Roll length <span data-unit-big>(m)</span></label>
          <div class="input-wrap"><input id="wpRollLength" type="number" value="10" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="wpRollWidth">Roll width <span data-unit-small>(cm)</span></label>
          <div class="input-wrap"><input id="wpRollWidth" type="number" value="53" min="0" step="0.1" /></div>
        </div>
        <div class="field">
          <label for="wpRepeat">Pattern repeat <span data-unit-small>(cm)</span></label>
          <div class="input-wrap"><input id="wpRepeat" type="number" value="0" min="0" step="0.1" /></div>
        </div>
      </div>
    </div>

    <button class="calc-cta" id="calculateWallpaper" type="button">Calculate rolls</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Rolls needed</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Rolls to buy</span><strong id="wpRolls" aria-live="polite">5</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Drops needed</span><b id="wpDrops">19</b></div>
      <div class="result-stat"><span>Drops per roll</span><b id="wpDropsPerRoll">4</b></div>
    </div>
    <p class="result-note" id="wpNote">Enter 0 pattern repeat for plain or random-match paper.</p>
  </aside>
</div>

<CalcShell label="Rolls needed" valueSelector="#wpRolls" />

<script>
  const root = document.getElementById('wallpaper-calculator');
  if (root) {
    const v = (id: string) => parseFloat((root.querySelector(`#${id}`) as HTMLInputElement).value) || 0;
    const unitSelect = root.querySelector<HTMLSelectElement>('#wpUnit')!;
    const bigLabels = root.querySelectorAll<HTMLElement>('[data-unit-big]');
    const smallLabels = root.querySelectorAll<HTMLElement>('[data-unit-small]');
    const noteEl = document.getElementById('wpNote')!;

    function updateUnitLabels() {
      const metric = unitSelect.value === 'metric';
      bigLabels.forEach((el) => (el.textContent = metric ? '(m)' : '(ft)'));
      smallLabels.forEach((el) => (el.textContent = metric ? '(cm)' : '(in)'));
    }

    function calculate() {
      const metric = unitSelect.value === 'metric';
      const wallLength = v('wpWallLength');
      const wallHeight = v('wpWallHeight');
      const rollLength = v('wpRollLength');
      const smallToBig = metric ? 100 : 12;
      const rollWidth = v('wpRollWidth') / smallToBig;
      const patternRepeat = v('wpRepeat') / smallToBig;

      const dropLength = wallHeight + patternRepeat;
      if (!rollWidth || !rollLength || dropLength <= 0 || dropLength > rollLength) {
        noteEl.textContent = 'Roll length must be greater than wall height plus pattern repeat.';
        noteEl.style.color = 'var(--warning)';
        document.getElementById('wpRolls')!.textContent = '—';
        return;
      }
      noteEl.style.color = '';
      noteEl.textContent = 'Enter 0 pattern repeat for plain or random-match paper.';

      const round6 = (n: number) => Math.round(n * 1e6) / 1e6;
      const dropsPerRoll = Math.max(Math.floor(round6(rollLength / dropLength)), 1);
      const totalDrops = Math.ceil(round6(wallLength / rollWidth));
      const rolls = Math.ceil(round6(totalDrops / dropsPerRoll));

      document.getElementById('wpRolls')!.textContent = String(rolls);
      document.getElementById('wpDrops')!.textContent = String(totalDrops);
      document.getElementById('wpDropsPerRoll')!.textContent = String(dropsPerRoll);
    }

    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', calculate));
    unitSelect.addEventListener('change', () => {
      updateUnitLabels();
      calculate();
    });
    document.getElementById('calculateWallpaper')?.addEventListener('click', calculate);

    updateUnitLabels();
    calculate();
  }
</script>
