---
import CalcShell from '../CalcShell.astro';
import Callout from '../Callout.astro';
---

<div class="calc-shell" id="zakat-gold-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Gold weight &amp; purity</h2>
      <div class="form-grid">
        <div class="field">
          <label for="zgWeight">Weight</label>
          <div class="input-wrap">
            <input id="zgWeight" type="number" value="100" min="0" step="0.001" />
            <select id="zgUnit" aria-label="Weight unit"><option value="grams" selected>Grams</option><option value="tola">Tola</option></select>
          </div>
        </div>
        <div class="field">
          <label for="zgKarat">Karat</label>
          <div class="input-wrap">
            <select id="zgKarat" style="border:0;flex:1">
              <option value="24">24k (pure)</option>
              <option value="22" selected>22k</option>
              <option value="21">21k</option>
              <option value="18">18k</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Price &amp; currency</h2>
      <div class="form-grid">
        <div class="field">
          <label for="zgPrice">Price per gram of 24k gold</label>
          <div class="input-wrap"><input id="zgPrice" type="number" value="70" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label for="zgCurrency">Currency label</label>
          <div class="input-wrap"><input id="zgCurrency" type="text" maxlength="8" value="$" /></div>
        </div>
      </div>
      <Callout variant="note" title="Jewelry worn for personal use">
        <p>
          The Hanafi school considers all gold zakatable, including worn jewelry, while the
          Maliki, Shafiʿi, and Hanbali schools generally exempt jewelry in regular personal use.
        </p>
      </Callout>
    </div>

    <button class="calc-cta" id="calculateZakatGold" type="button">Calculate zakat</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Zakat due (2.5%)</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Amount due</span><strong id="zgDue" aria-live="polite">$160.42</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Pure gold</span><b id="zgPureGrams">91.67 g</b></div>
      <div class="result-stat"><span>Gold value</span><b id="zgValue">$6416.67</b></div>
    </div>
    <p class="result-note" id="zgNisabNote"></p>
    <Callout variant="info" title="Part of your total wealth">
      <p>
        Zakat is normally assessed on total zakatable wealth. Use the
        <a href="/islamic/zakat-calculator/">Zakat Calculator</a> to combine this with cash and other assets.
      </p>
    </Callout>
  </aside>
</div>

<CalcShell label="Zakat due" valueSelector="#zgDue" />

<script>
  import { KARAT_PURITY, NISAB_GOLD_GRAMS, TOLA_IN_GRAMS, ZAKAT_RATE } from '../../data/islamic';

  const root = document.getElementById('zakat-gold-calculator');
  if (root) {
    const weightInput = root.querySelector<HTMLInputElement>('#zgWeight')!;
    const unitSelect = root.querySelector<HTMLSelectElement>('#zgUnit')!;
    const karatSelect = root.querySelector<HTMLSelectElement>('#zgKarat')!;
    const currencyInput = root.querySelector<HTMLInputElement>('#zgCurrency')!;
    const priceInput = root.querySelector<HTMLInputElement>('#zgPrice')!;

    function calculate() {
      const currency = currencyInput.value.trim() || '$';
      const weight = Math.max(0, parseFloat(weightInput.value) || 0);
      const karat = parseInt(karatSelect.value, 10);
      const price = Math.max(0, parseFloat(priceInput.value) || 0);

      const weightGrams = unitSelect.value === 'tola' ? weight * TOLA_IN_GRAMS : weight;
      const purity = KARAT_PURITY[karat] ?? 1;
      const pureGoldGrams = weightGrams * purity;
      const goldValue = pureGoldGrams * price;
      const zakatDue = goldValue * ZAKAT_RATE;

      document.getElementById('zgDue')!.textContent = `${currency}${zakatDue.toFixed(2)}`;
      document.getElementById('zgPureGrams')!.textContent = `${pureGoldGrams.toFixed(2)} g`;
      document.getElementById('zgValue')!.textContent = `${currency}${goldValue.toFixed(2)}`;

      document.getElementById('zgNisabNote')!.textContent =
        weightGrams >= NISAB_GOLD_GRAMS
          ? `This weight (${weightGrams.toFixed(2)} g) meets the gold nisab of ${NISAB_GOLD_GRAMS} g on its own.`
          : `This weight (${weightGrams.toFixed(2)} g) is below the ${NISAB_GOLD_GRAMS} g gold nisab alone — it may still be zakatable combined with other wealth.`;
    }

    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', calculate));
    unitSelect.addEventListener('change', calculate);
    karatSelect.addEventListener('change', calculate);
    document.getElementById('calculateZakatGold')?.addEventListener('click', calculate);

    calculate();
  }
</script>
