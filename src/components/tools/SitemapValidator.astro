---
import Callout from '../Callout.astro';
---

<div class="calc-shell" id="sitemap-validator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Input mode</h2>
      <div class="form-grid">
        <div class="field">
          <label for="sitemapMode">Mode</label>
          <div class="input-wrap">
            <select id="sitemapMode" style="border:0;flex:1">
              <option value="paste" selected>Paste XML</option>
              <option value="url">Fetch by URL</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Sitemap</h2>
      <div id="sitemapPasteFields" class="field">
        <label for="sitemapInput">Sitemap XML</label>
        <div class="input-wrap" style="height:auto">
          <textarea id="sitemapInput" rows="12" class="sitemap-textarea" style="border:0;outline:0;width:100%;padding:11px;background:transparent;font:inherit;color:inherit"></textarea>
        </div>
      </div>

      <div id="sitemapUrlFields" class="field" hidden>
        <label for="sitemapUrl">Sitemap URL</label>
        <div class="input-wrap"><input id="sitemapUrl" type="url" placeholder="https://example.com/sitemap.xml" /></div>
      </div>

      <button class="calc-cta" id="sitemapFetch" type="button" hidden>Fetch &amp; validate</button>
      <p class="result-note" id="sitemapFetchError"></p>

      <div class="tabs" style="margin-top:13px">
        <button class="tab" id="sitemapLoadValid" type="button">Load valid example</button>
        <button class="tab" id="sitemapLoadBroken" type="button">Load broken example</button>
        <button class="tab" id="sitemapClear" type="button">Clear</button>
      </div>
    </div>

    <Callout variant="note" title="Cross-origin fetching (CORS)">
      <p>
        Fetching a sitemap by URL relies on the target site allowing cross-origin requests, which
        most sites don't. If the fetch fails, paste the sitemap XML directly instead.
      </p>
    </Callout>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Validation result</h2><span class="status" id="sitemapStatus">—</span></div>
    <p class="result-note" id="sitemapStats"></p>
    <div id="sitemapIssues"></div>
  </aside>
</div>

<style>
  .sitemap-issue-list {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sitemap-issue-list li {
    font-size: 12.5px;
    padding: 8px 11px;
    border-radius: 8px;
    border-left: 3px solid #dc2626;
    background: var(--canvas);
  }
  .sitemap-issue-list li.warning {
    border-left-color: var(--warning);
  }
</style>

<script>
  const SITEMAP_NS = 'http://www.sitemaps.org/schemas/sitemap/0.9';
  const CHANGEFREQ_VALUES = ['always', 'hourly', 'daily', 'weekly', 'monthly', 'yearly', 'never'];
  const W3C_DATETIME_RE =
    /^\d{4}(-(0[1-9]|1[0-2])(-(0[1-9]|[12]\d|3[01])(T([01]\d|2[0-3]):[0-5]\d(:[0-5]\d(\.\d+)?)?(Z|[+-]([01]\d|2[0-3]):[0-5]\d)?)?)?)?$/;
  const MAX_URLS = 50000;
  const MAX_BYTES = 50 * 1024 * 1024;

  interface ValidationResult {
    ok: boolean;
    errors: string[];
    warnings: string[];
    stats: { type: string; count: number; withLastmod: number };
  }

  function isValidAbsoluteUrl(value: string): boolean {
    try {
      const u = new URL(value);
      return u.protocol === 'http:' || u.protocol === 'https:';
    } catch {
      return false;
    }
  }

  function validateSitemap(xmlString: string): ValidationResult {
    const errors: string[] = [];
    const warnings: string[] = [];

    const byteSize = new Blob([xmlString]).size;
    if (byteSize > MAX_BYTES) {
      warnings.push(`File is ${(byteSize / (1024 * 1024)).toFixed(1)} MB, exceeding the recommended 50 MB uncompressed limit.`);
    }

    const doc = new DOMParser().parseFromString(xmlString, 'application/xml');
    const parserError = doc.querySelector('parsererror');
    if (parserError) {
      errors.push(`XML is not well-formed: ${parserError.textContent?.trim().slice(0, 200)}`);
      return { ok: false, errors, warnings, stats: { type: 'unknown', count: 0, withLastmod: 0 } };
    }

    const root = doc.documentElement;
    const localName = root.localName;
    const namespaceOk = root.namespaceURI === SITEMAP_NS;

    if (!namespaceOk) {
      errors.push(`Root element namespace should be "${SITEMAP_NS}", found "${root.namespaceURI ?? 'none'}".`);
    }

    if (localName !== 'urlset' && localName !== 'sitemapindex') {
      errors.push(`Root element must be <urlset> or <sitemapindex>, found <${localName}>.`);
      return { ok: false, errors, warnings, stats: { type: localName, count: 0, withLastmod: 0 } };
    }

    const entryTag = localName === 'urlset' ? 'url' : 'sitemap';
    const entries = Array.from(root.getElementsByTagNameNS(SITEMAP_NS, entryTag));
    const entriesFallback = entries.length > 0 ? entries : Array.from(root.getElementsByTagName(entryTag));

    let withLastmod = 0;

    entriesFallback.forEach((entry, index) => {
      const locEl = entry.getElementsByTagName('loc')[0];
      const label = `${entryTag} #${index + 1}`;

      if (!locEl || !locEl.textContent?.trim()) {
        errors.push(`${label}: missing required <loc> element.`);
      } else if (!isValidAbsoluteUrl(locEl.textContent.trim())) {
        errors.push(`${label}: <loc> is not a valid absolute URL — "${locEl.textContent.trim()}".`);
      }

      const lastmodEl = entry.getElementsByTagName('lastmod')[0];
      if (lastmodEl && lastmodEl.textContent?.trim()) {
        withLastmod++;
        if (!W3C_DATETIME_RE.test(lastmodEl.textContent.trim())) {
          errors.push(`${label}: <lastmod> "${lastmodEl.textContent.trim()}" is not a valid W3C datetime.`);
        }
      }

      if (entryTag === 'url') {
        const changefreqEl = entry.getElementsByTagName('changefreq')[0];
        if (changefreqEl && changefreqEl.textContent?.trim()) {
          const value = changefreqEl.textContent.trim().toLowerCase();
          if (!CHANGEFREQ_VALUES.includes(value)) {
            errors.push(`${label}: <changefreq> "${value}" is not one of the allowed values.`);
          }
        }

        const priorityEl = entry.getElementsByTagName('priority')[0];
        if (priorityEl && priorityEl.textContent?.trim()) {
          const value = parseFloat(priorityEl.textContent.trim());
          if (Number.isNaN(value) || value < 0 || value > 1) {
            errors.push(`${label}: <priority> "${priorityEl.textContent.trim()}" must be between 0.0 and 1.0.`);
          }
        }
      }
    });

    if (entriesFallback.length > MAX_URLS) {
      warnings.push(`Sitemap has ${entriesFallback.length} entries, exceeding the recommended limit of ${MAX_URLS.toLocaleString()} per file.`);
    }

    return {
      ok: errors.length === 0,
      errors,
      warnings,
      stats: { type: localName, count: entriesFallback.length, withLastmod },
    };
  }

  const VALID_EXAMPLE = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://example.com/</loc>
    <lastmod>2026-06-01</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://example.com/about/</loc>
    <lastmod>2026-05-15</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
</urlset>`;

  const BROKEN_EXAMPLE = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>not-an-absolute-url</loc>
    <lastmod>2026-13-40</lastmod>
    <changefreq>often</changefreq>
    <priority>3.5</priority>
  </url>
  <url>
    <lastmod>2026-06-01</lastmod>
  </url>
</urlset>`;

  const root = document.getElementById('sitemap-validator');
  if (root) {
    const modeSelect = root.querySelector<HTMLSelectElement>('#sitemapMode')!;
    const pasteFields = document.getElementById('sitemapPasteFields')!;
    const urlFields = document.getElementById('sitemapUrlFields')!;
    const fetchBtn = document.getElementById('sitemapFetch') as HTMLButtonElement;
    const input = root.querySelector<HTMLTextAreaElement>('#sitemapInput')!;
    const urlInput = root.querySelector<HTMLInputElement>('#sitemapUrl')!;
    const loadValidBtn = document.getElementById('sitemapLoadValid')!;
    const loadBrokenBtn = document.getElementById('sitemapLoadBroken')!;
    const clearBtn = document.getElementById('sitemapClear')!;
    const fetchError = document.getElementById('sitemapFetchError')!;
    const statusEl = document.getElementById('sitemapStatus')!;
    const statsEl = document.getElementById('sitemapStats')!;
    const issuesEl = document.getElementById('sitemapIssues')!;

    function render() {
      const xml = input.value;
      if (!xml.trim()) {
        statusEl.textContent = '—';
        statsEl.textContent = '';
        issuesEl.innerHTML = '';
        return;
      }

      const result = validateSitemap(xml);
      statusEl.textContent = result.ok ? '✅ Valid' : '❌ Invalid';
      statsEl.textContent = `Type: ${result.stats.type} — ${result.stats.count} entries, ${result.stats.withLastmod} with <lastmod>`;

      const items = [
        ...result.errors.map((e) => ({ text: e, cls: '' })),
        ...result.warnings.map((w) => ({ text: w, cls: 'warning' })),
      ];

      issuesEl.innerHTML = '';
      if (items.length > 0) {
        const list = document.createElement('ul');
        list.className = 'sitemap-issue-list';
        items.forEach((item) => {
          const li = document.createElement('li');
          li.textContent = item.text;
          if (item.cls) li.className = item.cls;
          list.appendChild(li);
        });
        issuesEl.appendChild(list);
      }
    }

    function updateModeVisibility() {
      const isPaste = modeSelect.value === 'paste';
      pasteFields.hidden = !isPaste;
      (loadValidBtn as HTMLElement).hidden = !isPaste;
      (loadBrokenBtn as HTMLElement).hidden = !isPaste;
      (clearBtn as HTMLElement).hidden = !isPaste;
      urlFields.hidden = isPaste;
      fetchBtn.hidden = isPaste;
      fetchError.textContent = '';
    }

    modeSelect.addEventListener('change', updateModeVisibility);
    input.addEventListener('input', render);

    loadValidBtn.addEventListener('click', () => {
      input.value = VALID_EXAMPLE;
      render();
    });
    loadBrokenBtn.addEventListener('click', () => {
      input.value = BROKEN_EXAMPLE;
      render();
    });
    clearBtn.addEventListener('click', () => {
      input.value = '';
      render();
    });

    fetchBtn.addEventListener('click', async () => {
      const url = urlInput.value.trim();
      if (!url) return;
      fetchError.textContent = '';
      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error(`Request failed with status ${res.status}`);
        const text = await res.text();
        modeSelect.value = 'paste';
        updateModeVisibility();
        input.value = text;
        render();
      } catch {
        fetchError.textContent =
          'This site blocks cross-origin requests (CORS), or the URL could not be reached. Paste the sitemap XML directly instead.';
      }
    });

    updateModeVisibility();
    input.value = VALID_EXAMPLE;
    render();
  }
</script>
