---
import Callout from '../Callout.astro';
---

<div class="calc-shell" id="slug-generator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Text to slugify</h2>
      <div class="field">
        <label for="slugInput">Your text</label>
        <div class="input-wrap" style="height:auto">
          <textarea id="slugInput" rows="3" style="border:0;outline:0;width:100%;padding:11px;background:transparent;font:inherit;color:inherit">10 Best Café Recipes — Ünïcode &amp; Accents!</textarea>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Options</h2>
      <div class="form-grid">
        <div class="field">
          <label for="slugSeparator">Separator</label>
          <div class="input-wrap"><select id="slugSeparator" style="border:0;flex:1"><option value="-" selected>Hyphen (-)</option><option value="_">Underscore (_)</option></select></div>
        </div>
        <div class="field">
          <label for="slugMaxLength">Max length (optional)</label>
          <div class="input-wrap"><input id="slugMaxLength" type="number" min="1" step="1" placeholder="No limit" /></div>
        </div>
      </div>
      <div class="form-grid" style="margin-top:13px">
        <div class="field"><label><input type="checkbox" id="slugLowercase" checked /> Lowercase</label></div>
        <div class="field"><label><input type="checkbox" id="slugStopwords" /> Strip common stopwords</label></div>
      </div>
    </div>

    <Callout variant="note" title="A note on non-Latin scripts">
      <p>
        Latin-based text with accents is handled cleanly — é → e, ü → u. Non-Latin scripts (Arabic,
        Chinese, and others) may transliterate imperfectly or be dropped, since a slug is meant to
        stay within the URL-safe ASCII character set.
      </p>
    </Callout>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Slug</h2><span class="status">Live</span></div>
    <div class="primary-result"><span>Generated slug</span><strong id="slugOutput" style="font-size:22px;font-family:var(--font-mono);word-break:break-all" aria-live="polite">—</strong></div>
    <button class="calc-cta" id="slugCopy" type="button">Copy slug</button>
  </aside>
</div>

<script>
  import slugify from '@sindresorhus/slugify';

  const STOPWORDS = new Set([
    'a', 'an', 'the', 'and', 'or', 'but', 'of', 'in', 'on', 'at', 'to', 'for',
    'with', 'by', 'is', 'it', 'this', 'that', 'as', 'be', 'are',
  ]);

  function stripStopwords(text: string): string {
    return text
      .split(/\s+/)
      .filter((word) => !STOPWORDS.has(word.toLowerCase()))
      .join(' ');
  }

  const root = document.getElementById('slug-generator');
  if (root) {
    const input = root.querySelector<HTMLTextAreaElement>('#slugInput')!;
    const separatorSelect = root.querySelector<HTMLSelectElement>('#slugSeparator')!;
    const maxLengthInput = root.querySelector<HTMLInputElement>('#slugMaxLength')!;
    const lowercaseCheckbox = root.querySelector<HTMLInputElement>('#slugLowercase')!;
    const stopwordsCheckbox = root.querySelector<HTMLInputElement>('#slugStopwords')!;
    const output = document.getElementById('slugOutput')!;
    const copyBtn = document.getElementById('slugCopy') as HTMLButtonElement;

    function calculate() {
      const separator = separatorSelect.value;
      const raw = stopwordsCheckbox.checked ? stripStopwords(input.value) : input.value;

      let slug = slugify(raw, {
        separator,
        lowercase: lowercaseCheckbox.checked,
      });

      const maxLength = parseInt(maxLengthInput.value, 10);
      if (!Number.isNaN(maxLength) && maxLength > 0 && slug.length > maxLength) {
        slug = slug.slice(0, maxLength).replace(new RegExp(`\\${separator}+$`), '');
      }

      output.textContent = slug || '—';
    }

    input.addEventListener('input', calculate);
    separatorSelect.addEventListener('change', calculate);
    maxLengthInput.addEventListener('input', calculate);
    [lowercaseCheckbox, stopwordsCheckbox].forEach((el) => el.addEventListener('change', calculate));

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(output.textContent ?? '');
        copyBtn.textContent = 'Copied!';
        setTimeout(() => (copyBtn.textContent = 'Copy slug'), 1500);
      } catch {
        // Clipboard API unavailable; silently ignore.
      }
    });

    calculate();
  }
</script>
