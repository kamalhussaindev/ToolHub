---
import CalcShell from '../CalcShell.astro';
---

<div class="calc-shell" id="fabric-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Project &amp; dimensions</h2>
      <div class="form-grid">
        <div class="field">
          <label for="fabProject">Project type</label>
          <div class="input-wrap"><select id="fabProject" style="border:0;flex:1"><option value="curtains">Curtains</option><option value="upholstery">Upholstery / cushions</option></select></div>
        </div>
        <div class="field">
          <label for="fabUnit">Units</label>
          <div class="input-wrap"><select id="fabUnit" style="border:0;flex:1"><option value="metric">Metric (m / cm)</option><option value="imperial">Imperial (ft / in)</option></select></div>
        </div>
        <div class="field">
          <label id="fabWidthLabel" for="fabWidth">Track width <span data-unit-big>(m)</span></label>
          <div class="input-wrap"><input id="fabWidth" type="number" value="3" min="0" step="0.01" /></div>
        </div>
        <div class="field">
          <label id="fabDropLabel" for="fabDrop">Finished drop <span data-unit-big>(m)</span></label>
          <div class="input-wrap"><input id="fabDrop" type="number" value="2.4" min="0" step="0.01" /></div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Fabric &amp; pattern</h2>
      <div class="form-grid">
        <div class="field">
          <label for="fabRollWidth">Fabric roll width <span data-unit-small>(cm)</span></label>
          <div class="input-wrap"><input id="fabRollWidth" type="number" value="137" min="0" step="0.1" /></div>
        </div>
        <div class="field">
          <label for="fabRepeat">Pattern repeat <span data-unit-small>(cm)</span></label>
          <div class="input-wrap"><input id="fabRepeat" type="number" value="0" min="0" step="0.1" /></div>
        </div>
        <div class="field" data-fullness-field>
          <label for="fabFullness">Fullness ratio</label>
          <div class="input-wrap"><input id="fabFullness" type="number" value="2" min="1" step="0.1" /></div>
        </div>
        <div class="field" data-panels-field hidden>
          <label for="fabPanels">Number of panels</label>
          <div class="input-wrap"><input id="fabPanels" type="number" value="1" min="1" step="1" /></div>
        </div>
        <div class="field">
          <label for="fabAllowance">Hem &amp; heading allowance <span data-unit-small>(cm)</span></label>
          <div class="input-wrap"><input id="fabAllowance" type="number" value="25" min="0" step="0.1" /></div>
        </div>
      </div>
    </div>

    <button class="calc-cta" id="calculateFabric" type="button">Calculate fabric</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Fabric needed</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Total fabric</span><strong id="fabTotal" aria-live="polite">13.25 m</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Widths / panels</span><b id="fabWidths">5</b></div>
      <div class="result-stat"><span>Cut length</span><b id="fabCutLength">2.65 m</b></div>
    </div>
    <p class="result-note">Fullness and pattern repeat both increase how much fabric you need.</p>
  </aside>
</div>

<CalcShell label="Fabric needed" valueSelector="#fabTotal" />

<script>
  const root = document.getElementById('fabric-calculator');
  if (root) {
    const v = (id: string) => parseFloat((root.querySelector(`#${id}`) as HTMLInputElement).value) || 0;
    const projectSelect = root.querySelector<HTMLSelectElement>('#fabProject')!;
    const unitSelect = root.querySelector<HTMLSelectElement>('#fabUnit')!;
    const bigLabels = root.querySelectorAll<HTMLElement>('[data-unit-big]');
    const smallLabels = root.querySelectorAll<HTMLElement>('[data-unit-small]');
    const widthLabel = document.getElementById('fabWidthLabel')!;
    const dropLabel = document.getElementById('fabDropLabel')!;
    const fullnessField = root.querySelector<HTMLElement>('[data-fullness-field]')!;
    const panelsField = root.querySelector<HTMLElement>('[data-panels-field]')!;

    function updateLabels() {
      const metric = unitSelect.value === 'metric';
      bigLabels.forEach((el) => (el.textContent = metric ? '(m)' : '(ft)'));
      smallLabels.forEach((el) => (el.textContent = metric ? '(cm)' : '(in)'));

      const isCurtains = projectSelect.value === 'curtains';
      widthLabel.childNodes[0].textContent = isCurtains ? 'Track width ' : 'Panel width ';
      dropLabel.childNodes[0].textContent = isCurtains ? 'Finished drop ' : 'Panel height ';
      fullnessField.hidden = !isCurtains;
      panelsField.hidden = isCurtains;
    }

    function calculate() {
      const metric = unitSelect.value === 'metric';
      const isCurtains = projectSelect.value === 'curtains';
      const smallToBig = metric ? 100 : 12;

      const width = v('fabWidth');
      const drop = v('fabDrop');
      const rollWidth = v('fabRollWidth') / smallToBig;
      const patternRepeat = v('fabRepeat') / smallToBig;
      const fullness = isCurtains ? v('fabFullness') : 1;
      const panels = isCurtains ? 1 : Math.max(v('fabPanels') || 1, 1);
      const allowance = v('fabAllowance') / smallToBig;

      if (!rollWidth || !width || !drop) return;

      const round6 = (n: number) => Math.round(n * 1e6) / 1e6;
      const totalWidthNeeded = width * fullness;
      const widthsOfFabric = Math.max(Math.ceil(round6(totalWidthNeeded / rollWidth)), 1);
      const rawDrop = drop + allowance;
      const cutDropLength = patternRepeat > 0 ? Math.ceil(round6(rawDrop / patternRepeat)) * patternRepeat : rawDrop;
      const totalFabric = widthsOfFabric * cutDropLength * panels;
      const unitLabel = metric ? 'm' : 'ft';

      document.getElementById('fabTotal')!.textContent = `${totalFabric.toFixed(2)} ${unitLabel}`;
      document.getElementById('fabWidths')!.textContent = String(isCurtains ? widthsOfFabric : panels);
      document.getElementById('fabCutLength')!.textContent = `${cutDropLength.toFixed(2)} ${unitLabel}`;
    }

    root.querySelectorAll('input').forEach((el) => el.addEventListener('input', calculate));
    unitSelect.addEventListener('change', () => {
      updateLabels();
      calculate();
    });
    projectSelect.addEventListener('change', () => {
      updateLabels();
      calculate();
    });
    document.getElementById('calculateFabric')?.addEventListener('click', calculate);

    updateLabels();
    calculate();
  }
</script>
