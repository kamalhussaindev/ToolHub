---
import CalcShell from '../CalcShell.astro';
---

<div class="calc-shell" id="tile-calculator">
  <section class="calc-card">
    <div class="calc-block">
      <h2><span class="step">1</span>Area to be tiled</h2>
      <div class="form-grid">
        <div class="field">
          <label for="roomL">Room length</label>
          <div class="input-wrap">
            <input id="roomL" type="number" value="4" min="0" step="0.1" />
            <select id="roomLUnit" aria-label="Room length unit"><option value="m">m</option><option value="ft">ft</option></select>
          </div>
        </div>
        <div class="field">
          <label for="roomW">Room width</label>
          <div class="input-wrap">
            <input id="roomW" type="number" value="3.6" min="0" step="0.1" />
            <select id="roomWUnit" aria-label="Room width unit"><option value="m">m</option><option value="ft">ft</option></select>
          </div>
        </div>
      </div>
    </div>

    <div class="calc-block">
      <h2><span class="step">2</span>Tile requirements</h2>
      <div class="form-grid">
        <div class="field">
          <label for="tileL">Tile length</label>
          <div class="input-wrap">
            <input id="tileL" type="number" value="60" min="0" />
            <select id="tileLUnit" aria-label="Tile length unit"><option value="cm">cm</option><option value="in">in</option></select>
          </div>
        </div>
        <div class="field">
          <label for="tileW">Tile width</label>
          <div class="input-wrap">
            <input id="tileW" type="number" value="60" min="0" />
            <select id="tileWUnit" aria-label="Tile width unit"><option value="cm">cm</option><option value="in">in</option></select>
          </div>
        </div>
        <div class="field">
          <label for="waste">Waste factor</label>
          <div class="input-wrap">
            <input id="waste" type="number" value="10" min="0" />
            <select aria-hidden="true" tabindex="-1"><option>%</option></select>
          </div>
        </div>
        <div class="field">
          <label for="perBox">Tiles per box</label>
          <div class="input-wrap">
            <input id="perBox" type="number" value="5" min="1" />
            <select aria-hidden="true" tabindex="-1"><option>tiles</option></select>
          </div>
        </div>
      </div>
    </div>

    <button class="calc-cta" id="calculateTile" type="button">Calculate tiles</button>
  </section>

  <aside class="result-card">
    <div class="result-head"><h2>Materials needed</h2><span class="status">Live estimate</span></div>
    <div class="primary-result"><span>Tiles required</span><strong id="tilesResult" aria-live="polite">44</strong></div>
    <div class="result-grid">
      <div class="result-stat"><span>Boxes to buy</span><b id="boxesResult">9</b></div>
      <div class="result-stat"><span>Total area</span><b id="areaResult">14.4 m²</b></div>
      <div class="result-stat"><span>Waste area</span><b id="wasteResult">1.44 m²</b></div>
      <div class="result-stat"><span>Extra tiles</span><b id="extraResult">1</b></div>
    </div>
    <p class="result-note">This estimate rounds tile and box quantities up to whole units.</p>
  </aside>
</div>

<CalcShell label="Tiles needed" valueSelector="#tilesResult" />

<script>
  const root = document.getElementById('tile-calculator');
  if (root) {
    const v = (id: string) => parseFloat((root.querySelector(`#${id}`) as HTMLInputElement).value) || 0;
    const unit = (id: string) => (root.querySelector(`#${id}`) as HTMLSelectElement).value;
    const roomFactor = (id: string) => (unit(id) === 'ft' ? 0.3048 : 1);
    const tileFactor = (id: string) => (unit(id) === 'in' ? 0.0254 : 0.01);

    const ids = ['roomL', 'roomW', 'tileL', 'tileW', 'waste', 'perBox', 'roomLUnit', 'roomWUnit', 'tileLUnit', 'tileWUnit'];

    function calculateTile() {
      const area = v('roomL') * roomFactor('roomLUnit') * v('roomW') * roomFactor('roomWUnit');
      const tileArea = v('tileL') * tileFactor('tileLUnit') * v('tileW') * tileFactor('tileWUnit');
      const waste = v('waste') / 100;
      const raw = tileArea ? (area * (1 + waste)) / tileArea : 0;
      // Round off floating-point noise (e.g. 14.4*1.1/0.36 = 44.00000000000001)
      // before ceiling, so a result that's mathematically a whole number
      // doesn't get bumped up to the next one.
      const tiles = Math.ceil(Math.round(raw * 1e6) / 1e6);
      const per = Math.max(1, v('perBox'));
      const boxes = Math.ceil(tiles / per);

      const tilesResult = document.getElementById('tilesResult')!;
      tilesResult.textContent = tiles.toLocaleString();
      document.getElementById('boxesResult')!.textContent = boxes.toLocaleString();
      document.getElementById('areaResult')!.textContent = area.toFixed(2) + ' m²';
      document.getElementById('wasteResult')!.textContent = (area * waste).toFixed(2) + ' m²';
      document.getElementById('extraResult')!.textContent = (boxes * per - tiles).toLocaleString();
    }

    ids.forEach((id) => root.querySelector(`#${id}`)?.addEventListener('input', calculateTile));
    document.getElementById('calculateTile')?.addEventListener('click', calculateTile);
    calculateTile();
  }
</script>
