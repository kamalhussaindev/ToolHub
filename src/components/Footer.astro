---
import { getSortedClusters } from '../data/clusters';
import { getToolsByCluster } from '../data/tools';

const clusters = getSortedClusters();
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    {clusters.map((cluster) => {
      const clusterTools = getToolsByCluster(cluster.slug).filter((t) => t.status === 'live');
      return (
        <div class="site-footer__col">
          <h2>{cluster.name}</h2>
          <ul>
            {clusterTools.length > 0 ? (
              clusterTools.map((tool) => (
                <li><a href={`/${cluster.slug}/${tool.slug}/`}>{tool.title}</a></li>
              ))
            ) : (
              <li><a href={`/${cluster.slug}/`}>Browse {cluster.name}</a></li>
            )}
          </ul>
        </div>
      );
    })}
    <div class="site-footer__col">
      <h2>Company</h2>
      <ul>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/privacy/">Privacy Policy</a></li>
        <li><a href="/terms/">Terms of Service</a></li>
      </ul>
    </div>
  </div>
  <div class="container site-footer__bottom">
    <p>&copy; {year} Tool Hub. All calculations run in your browser — your data is never uploaded.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-12);
  }
  .site-footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-6);
    padding: var(--space-10) 0 var(--space-8);
  }
  .site-footer__col h2 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }
  .site-footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .site-footer__col a {
    color: var(--color-text-body);
    font-size: var(--text-sm);
  }
  .site-footer__col a:hover {
    color: var(--color-primary);
  }
  .site-footer__bottom {
    border-top: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }
  .site-footer__bottom p {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
