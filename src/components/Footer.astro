---
import { getSortedClusters } from '../data/clusters';
import { icon } from '../data/icons';

const clusters = getSortedClusters();
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="shell">
    <div class="footer-grid">
      <div>
        <a class="brand" href="/"><span class="brand-mark" set:html={icon('grid')} /><span>Tool Hub</span></a>
        <p>Practical calculators, converters and everyday tools designed to give you a clear answer quickly.</p>
      </div>
      <div>
        <h4>Explore</h4>
        <a href="/">Home</a>
        <a href="/home-improvement/">Popular calculators</a>
        <a href="#" data-open-search>Search tools</a>
      </div>
      <div>
        <h4>Categories</h4>
        {clusters.map((cluster) => <a href={`/${cluster.slug}/`}>{cluster.name}</a>)}
      </div>
      <div>
        <h4>Resources</h4>
        <a href="/guides/">Guides</a>
        <a href="/guides/how-to-calculate-zakat/">How to calculate zakat</a>
      </div>
      <div>
        <h4>Company</h4>
        <a href="/about/">About</a>
        <a href="/privacy/">Privacy</a>
        <a href="/contact/">Contact</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} Tool Hub.</span>
      <span>Free tools · no sign-up required</span>
    </div>
  </div>
</footer>

<style>
  .footer .brand span:last-child {
    margin-left: 2px;
  }
</style>
